{
  "name": "ol-base-components",
  "version": "3.6.9",
  "private": false,
  "main": "dist/index.umd.js",
  "style": "dist/style.css",
  "sideEffects": [
    "dist/style.css",
    "dist/print-lock.css"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.umd.js",
      "default": "./dist/index.umd.js"
    },
    "./dist/style.css": "./dist/style.css",
    "./dist/print-lock.css": "./dist/print-lock.css"
  },
  "files": [
    "dist/",
    "src/api/",
    "src/bin/",
    "package.json"
  ],
  "bin": {
    "init": "src/api/init.js",
    "run": "src/api/run.js",
    "api": "src/api/api.js",
    "add": "src/bin/add.js",
    "ol:swagger": "src/bin/fetch-swagger.js"
  },
  "scripts": {
    "serve": "vue-cli-service serve --no-verify",
    "build": "vite build",
    "build:cli": "vue-cli-service build",
    "lint": "vue-cli-service lint",
    "add": "node src/bin/add.js",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "commander": "^14.0.0",
    "core-js": "^3.8.3",
    "eslint": "^8.57.1",
    "eslint-plugin-vue": "^10.3.0",
    "inquirer": "^8.2.6"
  },
  "devDependencies": {
    "@babel/core": "^7.12.16",
    "@babel/eslint-parser": "^7.12.16",
    "@types/vscode": "^1.60.0",
    "@vitejs/plugin-legacy": "^8.0.2",
    "@vue/babel-helper-vue-jsx-merge-props": "^1.4.0",
    "@vue/babel-preset-jsx": "^1.4.0",
    "@vue/cli-plugin-babel": "~5.0.0",
    "@vue/cli-plugin-eslint": "~5.0.0",
    "@vue/cli-service": "~5.0.0",
    "babel-plugin-transform-vue-jsx": "^3.7.0",
    "element-ui": "^2.15.14",
    "eslint-config-prettier": "^8.8.0",
    "eslint-plugin-prettier": "^4.2.1",
    "jquery": "^3.6.0",
    "prettier": "^2.8.8",
    "sass": "^1.89.2",
    "sass-loader": "^16.0.5",
    "sortablejs": "^1.15.7",
    "swagger-client": "^3.0.1",
    "vite": "^4.5.0",
    "vite-plugin-vue2": "^2.0.3",
    "vue": "^2.6.14",
    "vue-plugin-hiprint": "^0.0.60",
    "vue-template-compiler": "^2.6.14"
  },
  "eslintConfig": {
    "root": true,
    "env": {
      "node": true
    },
    "extends": [
      "plugin:vue/essential",
      "eslint:recommended"
    ],
    "parserOptions": {
      "parser": "@babel/eslint-parser"
    },
    "rules": {}
  },
  "keywords": [
    "ol-base-components"
  ],
  "description": "交互式命令行方式自动生成联调好的CRUD页面",
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not dead"
  ],
  "bugs": {
    "url": "https://github.com/time202051/base-component/issues",
    "email": "809949003@qq.com"
  },
  "license": "MIT",
  "author": "lijiapeng"
}